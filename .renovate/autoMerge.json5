{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Auto-merge GitHub Actions",
      matchManagers: ["github-actions"],
      automerge: true,
      automergeType: "pr",
      matchUpdateTypes: ["minor", "patch", "digest"],
      minimumReleaseAge: "3 days",
    },
    {
      // Generalized rule at the top so it can be overridden
      description: "Auto-merge Mise Tools",
      matchManagers: ["mise"],
      automerge: true,
      automergeType: "pr",
      matchUpdateTypes: ["minor", "patch"],
      ignoreTests: true,
    },
    {
      // Python minor version updates frequently introduce breaking changes to stdlib APIs
      // Example: Python 3.14's BooleanOptionalAction no longer accepts 'type' parameter,
      // breaking flux-local and other tools. Only auto-merge patch versions (security fixes).
      description: "Disable auto-merge for Mise Python minor/major",
      matchManagers: ["mise"],
      matchPackageNames: ["python"],
      matchUpdateTypes: ["minor", "major"],
      automerge: false,
    },
    {
      description: "Auto-merge OCI charts and containers",
      matchDatasources: ["docker"],
      excludePackageNames: ["/cilium/", "ghcr.io/rook/**"],
      automerge: true,
      automergeType: "pr",
      matchUpdateTypes: ["patch", "digest"],
      minimumReleaseAge: "5 days",
    },
    {
      // Per SemVer spec, 0.x versions may introduce breaking changes in any release.
      // tuppr 0.0.55 broke the cluster by adding self-signed webhook certs without notice.
      description: "Disable auto-merge for pre-1.0 packages",
      matchDatasources: ["docker"],
      matchCurrentVersion: "/^v?0/",
      automerge: false,
    },
    {
      // Override pre-1.0 block: mcp-searxng follows semver despite 0.x versioning
      description: "Auto-merge mcp-searxng minor and patch updates",
      matchDatasources: ["docker"],
      matchPackageNames: ["isokoliuk/mcp-searxng"],
      automerge: true,
      automergeType: "pr",
      matchUpdateTypes: ["minor", "patch"],
      minimumReleaseAge: "5 days",
    },
    {
      // Tag format: YYYY.M.DD-githash (e.g. 2026.4.3-c980fa1ef)
      // Default versioning can't parse this; regex extracts date parts
      description: "SearXNG date-based versioning",
      matchDatasources: ["docker"],
      matchPackageNames: ["ghcr.io/searxng/searxng"],
      versioning: "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-(?<build>[a-f0-9]+)$",
    },
    {
      description: "Auto-merge app-template chart updates",
      matchDatasources: ["docker"],
      matchPackageNames: ["/app-template/"],
      automerge: true,
      automergeType: "pr",
      matchUpdateTypes: ["patch"],
      minimumReleaseAge: "5 days",
    },
    {
      description: "Disable auto-merge for all Talos-related packages",
      matchPackageNames: ["/siderolabs/", "/talosctl/"],
      automerge: false,
    },
  ],
}
