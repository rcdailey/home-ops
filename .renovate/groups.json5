{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Cilium Group",
      groupName: "Cilium",
      matchPackageNames: ["/cilium/"],
      minimumGroupSize: 2,
    },
    {
      description: "Flux Operator Group",
      groupName: "Flux Operator",
      matchPackageNames: ["/flux-operator/", "/flux-instance/", "/flux-operator-manifests/"],
      minimumGroupSize: 3,
    },
    {
      description: "Immich Group",
      groupName: "Immich",
      matchPackageNames: ["ghcr.io/immich-app/**"],
      minimumGroupSize: 2,
    },
    {
      description: "Rook Ceph Group",
      groupName: "Rook Ceph",
      matchPackageNames: ["ghcr.io/rook/**"],
      minimumReleaseAge: "10 days",
      minimumGroupSize: 2,
    },
    {
      description: "MariaDB Operator",
      groupName: "MariaDB",
      matchPackageNames: ["/mariadb-operator/"],
      minimumGroupSize: 2,
    },
    {
      // Groups Kubernetes version upgrades across mise (kubectl), tuppr, and talenv (kubelet)
      description: "Kubernetes Group",
      groupName: "Kubernetes",
      matchPackageNames: ["/kubelet/", "/kubectl/"],
      minimumGroupSize: 3,
    },
    {
      // Groups Talos OS docker packages (installer image + tuppr upgrade spec)
      // Excludes kubelet (Kubernetes group) and talosctl (mise, bare semver without v prefix)
      // talosctl is excluded because its bare version (1.13.5) mismatches docker's v-prefixed
      // tags (v1.13.5), causing Renovate to drop version info from group commit messages
      description: "Talos Group",
      groupName: "Talos",
      matchPackageNames: [
        "/siderolabs/",
        "!/kubelet/",
        "!/talosctl/",
      ],
      minimumGroupSize: 2,
    },
  ],
}
