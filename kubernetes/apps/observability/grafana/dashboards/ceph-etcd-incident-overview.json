{
  "annotations": {
    "list": []
  },
  "description": "Correlate etcd fsync and disk latency spikes with API write pressure, disk utilization, and downstream cluster effects on control plane nodes",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 2,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "etcd leader",
      "description": "Which etcd member holds Raft leadership. Stable = one continuous green bar per member with no transitions.",
      "type": "state-timeline",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "id": 20,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-RdYlGr" },
          "custom": {
            "fillOpacity": 70,
            "insertNulls": false,
            "lineWidth": 0,
            "spanNulls": false
          },
          "mappings": [
            {
              "options": {
                "0": { "color": "purple", "index": 0, "text": "follower" },
                "1": { "color": "green", "index": 1, "text": "LEADER" }
              },
              "type": "value"
            }
          ],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "alignValue": "center",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "mergeValues": true,
        "rowHeight": 0.9,
        "showValue": "auto",
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "label_replace(etcd_server_is_leader{job=\"kube-etcd\"}, \"node_ip\", \"$1\", \"instance\", \"(.*):.*\") * on(node_ip) group_left(nodename) label_replace(node_uname_info, \"node_ip\", \"$1\", \"instance\", \"(.*):.*\")",
          "legendFormat": "{{nodename}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
      "id": 100,
      "title": "etcd Disk Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "WAL fsync p99",
      "description": "Time per WAL fsync (irate for spike fidelity). Every etcd write must fsync before acknowledgment. Spikes here correlate with disk saturation or write pressure from API activity.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": false,
            "axisBorderShow": false,
            "axisSoftMax": 0.025,
            "thresholdsStyle": { "mode": "area" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 0.005 },
              { "color": "red", "value": 0.01 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum by (instance, le) (irate(etcd_disk_wal_fsync_duration_seconds_bucket{job=\"kube-etcd\"}[$__rate_interval])))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "Backend commit p99",
      "description": "Time for boltdb to commit a transaction (irate for spike fidelity). Larger writes than WAL fsync; spikes here indicate sustained write pressure on the etcd database file.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 2,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": false,
            "axisBorderShow": false,
            "axisSoftMax": 0.1,
            "thresholdsStyle": { "mode": "area" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 0.025 },
              { "color": "red", "value": 0.1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum by (instance, le) (irate(etcd_disk_backend_commit_duration_seconds_bucket{job=\"kube-etcd\"}[$__rate_interval])))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 101,
      "title": "Disk Activity (sda)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "sda I/O utilization",
      "description": "Percentage of time the system disk is busy handling I/O. 100% means the disk is saturated; fsync latency will spike regardless of individual write size. Compare timing with WAL fsync spikes above.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 14 },
      "id": 30,
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "axisBorderShow": false,
            "thresholdsStyle": { "mode": "area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(node_disk_io_time_seconds_total{device=\"sda\"}[$__rate_interval]) * 100 * on(instance) group_left(nodename) node_uname_info{nodename=~\"$node\"}",
          "legendFormat": "{{nodename}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "sda write IOPS",
      "description": "Write operations per second on the system disk. High IOPS with low utilization = fast disk keeping up. High IOPS with high utilization = disk saturated by write volume.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 14 },
      "id": 31,
      "fieldConfig": {
        "defaults": {
          "unit": "iops",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": false,
            "axisBorderShow": false
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(node_disk_writes_completed_total{device=\"sda\"}[$__rate_interval]) * on(instance) group_left(nodename) node_uname_info{nodename=~\"$node\"}",
          "legendFormat": "{{nodename}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "sda write throughput",
      "description": "Bytes written per second to the system disk. Distinguishes 'many small writes' (high IOPS, low throughput) from 'few large writes' (low IOPS, high throughput). Large writes from log rotation or containerd can spike fsync latency even at moderate IOPS.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 14 },
      "id": 32,
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": false,
            "axisBorderShow": false
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(node_disk_written_bytes_total{device=\"sda\"}[$__rate_interval]) * on(instance) group_left(nodename) node_uname_info{nodename=~\"$node\"}",
          "legendFormat": "{{nodename}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "sda avg write latency",
      "description": "Average time per completed write operation. Complements the p99 etcd histograms above with a device-level view. When this rises but IOPS stays flat, the disk itself is struggling (thermal throttling, wear). When this rises with IOPS, the disk is simply overloaded.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "id": 33,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": false,
            "axisBorderShow": false,
            "axisSoftMax": 0.01,
            "thresholdsStyle": { "mode": "area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 0.005 },
              { "color": "red", "value": 0.01 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(node_disk_write_time_seconds_total{device=\"sda\"}[$__rate_interval]) / rate(node_disk_writes_completed_total{device=\"sda\"}[$__rate_interval]) * on(instance) group_left(nodename) node_uname_info{nodename=~\"$node\"}",
          "legendFormat": "{{nodename}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "sda I/O queue depth",
      "description": "Weighted average number of I/O operations in flight. Values above 1 mean the disk has a backlog; writes are queuing behind each other. Correlate with fsync latency: queue depth > 2 almost always means etcd is waiting in line behind other I/O.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "id": 34,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "axisBorderShow": false,
            "thresholdsStyle": { "mode": "area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 2 },
              { "color": "red", "value": 4 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(node_disk_io_time_weighted_seconds_total{device=\"sda\"}[$__rate_interval]) * on(instance) group_left(nodename) node_uname_info{nodename=~\"$node\"}",
          "legendFormat": "{{nodename}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "id": 102,
      "title": "Write Pressure Sources",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "API write rate by resource",
      "description": "Mutating API requests (POST/PUT/PATCH/DELETE) grouped by resource type. Shows what is generating etcd writes: leases, events, endpoints, configmaps, etc. Lease renewals are typically the dominant source; spikes in other resources point to specific workloads.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "id": 40,
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 30,
            "spanNulls": false,
            "axisBorderShow": false,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (resource) (rate(apiserver_request_total{verb=~\"POST|PUT|PATCH|DELETE\", job=\"apiserver\"}[$__rate_interval]))",
          "legendFormat": "{{resource}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "etcd object operations",
      "description": "Rate of put, delete, and range operations in etcd's MVCC store. Puts correlate directly with WAL fsync pressure. A spike in puts without a matching API write spike suggests internal Kubernetes bookkeeping (leader election, endpoint slice updates).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "id": 41,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": false,
            "axisBorderShow": false
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (instance) (rate(etcd_mvcc_put_total{job=\"kube-etcd\"}[$__rate_interval]))",
          "legendFormat": "put {{instance}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (instance) (rate(etcd_mvcc_delete_total{job=\"kube-etcd\"}[$__rate_interval]))",
          "legendFormat": "delete {{instance}}",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "API write rate by verb",
      "description": "Mutating API requests broken down by HTTP verb. Distinguishes creates (POST) from updates (PUT/PATCH) from deletes. A healthy cluster is dominated by PUT (lease renewals, status updates). Unusual POST spikes indicate batch job creation or controller churn.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 39 },
      "id": 42,
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": false,
            "axisBorderShow": false
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (verb) (rate(apiserver_request_total{verb=~\"POST|PUT|PATCH|DELETE\", job=\"apiserver\"}[$__rate_interval]))",
          "legendFormat": "{{verb}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "etcd DB size",
      "description": "Physical size of the etcd database. Gradual growth is normal; sudden jumps indicate bulk writes. A large DB means compaction and defragmentation take longer, which can cause fsync pressure during maintenance windows.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 39 },
      "id": 43,
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "axisBorderShow": false
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "etcd_mvcc_db_total_size_in_bytes{job=\"kube-etcd\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 47 },
      "id": 103,
      "title": "Downstream Effects",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "Slow applies",
      "description": "Raft proposals that took >100ms to apply. Each slow apply involves a disk fsync. Non-zero values confirm etcd is falling behind on processing writes.",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 48 },
      "id": 4,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "decimals": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50,
            "axisBorderShow": false,
            "axisSoftMax": 10,
            "thresholdsStyle": { "mode": "area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(etcd_server_slow_apply_total{job=\"kube-etcd\"}[$__rate_interval])",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "Leader changes",
      "description": "Leader elections per interval. Should be zero. Each change causes brief API unavailability.",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 48 },
      "id": 5,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "decimals": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50,
            "axisBorderShow": false,
            "axisSoftMax": 3,
            "thresholdsStyle": { "mode": "area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(etcd_server_leader_changes_seen_total{job=\"kube-etcd\"}[$__rate_interval])",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "Proposals pending",
      "description": "Raft proposals waiting to be committed. Sustained non-zero means the leader cannot commit fast enough. Correlate with disk utilization and IOPS above.",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 48 },
      "id": 6,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "axisBorderShow": false,
            "axisSoftMax": 50,
            "thresholdsStyle": { "mode": "area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 5 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
