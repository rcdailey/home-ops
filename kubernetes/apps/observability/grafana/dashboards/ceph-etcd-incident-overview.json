{
  "annotations": {
    "list": []
  },
  "description": "Proves etcd disk bottleneck: consumer SATA fsync latency causes leader instability, apiserver slowness, and Ceph mon quorum loss",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 2,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "etcd leader",
      "description": "Which etcd member holds the Raft leadership over time. Purple = follower, green = leader. A healthy cluster shows one continuous green bar per member with no transitions. Each color change is a leader election caused by the current leader failing to heartbeat in time (because fsync is too slow).",
      "type": "state-timeline",
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 0 },
      "id": 20,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-RdYlGr" },
          "custom": {
            "fillOpacity": 70,
            "insertNulls": false,
            "lineWidth": 0,
            "spanNulls": false
          },
          "mappings": [
            {
              "options": {
                "0": { "color": "purple", "index": 0, "text": "follower" },
                "1": { "color": "green", "index": 1, "text": "LEADER" }
              },
              "type": "value"
            }
          ],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "alignValue": "center",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "mergeValues": true,
        "rowHeight": 0.9,
        "showValue": "auto",
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "label_replace(etcd_server_is_leader{job=\"kube-etcd\"}, \"node_ip\", \"$1\", \"instance\", \"(.*):.*\") * on(node_ip) group_left(nodename) label_replace(node_uname_info, \"node_ip\", \"$1\", \"instance\", \"(.*):.*\")",
          "legendFormat": "{{nodename}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 100,
      "title": "Disk Performance (The Proof)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "WAL fsync p99",
      "description": "How long each WAL fsync takes. This is THE metric. Every etcd write must fsync to disk before it can be acknowledged. Consumer SATA SSDs (like Samsung 870 EVO) lack power-loss capacitors, so every fsync waits for data to reach physical media: 10-15ms typical, spiking to 50ms+. Enterprise SSDs with capacitors do this in <1ms because they can acknowledge as soon as data hits battery-backed cache. The yellow/red zones show where your drives should NOT be, but always are.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": false,
            "axisBorderShow": false,
            "axisSoftMax": 0.025,
            "thresholdsStyle": { "mode": "area" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 0.005 },
              { "color": "red", "value": 0.01 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, rate(etcd_disk_wal_fsync_duration_seconds_bucket{job=\"kube-etcd\"}[$__rate_interval]))",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "Backend commit p99",
      "description": "How long boltdb (etcd's storage engine) takes to commit a transaction to disk. This includes the fsync of the database file itself (separate from the WAL fsync). Spikes here are often worse than WAL fsync because boltdb commits are larger writes. Your cluster regularly hits 25-30ms with spikes to 800ms+. Enterprise SSDs bring this under 10ms.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "id": 2,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": false,
            "axisBorderShow": false,
            "axisSoftMax": 0.1,
            "thresholdsStyle": { "mode": "area" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 0.025 },
              { "color": "red", "value": 0.1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, rate(etcd_disk_backend_commit_duration_seconds_bucket{job=\"kube-etcd\"}[$__rate_interval]))",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "Disk write latency: sda (etcd) vs nvme (Ceph)",
      "description": "Average time per write operation for each physical device on control plane nodes. sda is the SATA SSD where etcd lives (Talos system disk). nvme0n1 is the NVMe where Ceph OSD lives. The gap between the two lines IS the problem: SATA is 2-4x slower per write. etcd needs the fast disk, but it's on the slow one. This panel proves the bottleneck is hardware, not software.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "id": 3,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": false,
            "axisBorderShow": false,
            "axisSoftMax": 0.01,
            "thresholdsStyle": { "mode": "off" }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(node_disk_write_time_seconds_total{device=~\"sda|nvme0n1\"}[$__rate_interval]) / rate(node_disk_writes_completed_total{device=~\"sda|nvme0n1\"}[$__rate_interval]) * on(instance) group_left(nodename) node_uname_info{nodename=~\"$node\"}",
          "legendFormat": "{{nodename}} / {{device}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 101,
      "title": "etcd Stability (The Damage)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "Slow applies",
      "description": "Raft proposals that took >100ms to apply. A healthy cluster with enterprise SSDs shows near zero. Your cluster shows 300-600 PER HOUR because every apply involves a disk fsync, and your consumer SATA SSDs can't keep up. This is the most damning metric: it means etcd is constantly falling behind on processing writes. When this spikes higher (1000+), you get leader elections and apiserver timeouts.",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 15 },
      "id": 4,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "decimals": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50,
            "axisBorderShow": false,
            "axisSoftMax": 10,
            "thresholdsStyle": { "mode": "area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(etcd_server_slow_apply_total{job=\"kube-etcd\"}[$__rate_interval])",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "Leader changes",
      "description": "Count of leader elections per interval. Should be zero (per buroa's cluster: 'never'). Each bar is a leadership transfer caused by the current leader's heartbeat timing out, which happens when fsync takes so long that etcd can't respond to peers in time. Even one change causes brief API unavailability; rapid changes cause cascading pod restarts across the cluster.",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 15 },
      "id": 5,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "decimals": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50,
            "axisBorderShow": false,
            "axisSoftMax": 3,
            "thresholdsStyle": { "mode": "area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(etcd_server_leader_changes_seen_total{job=\"kube-etcd\"}[$__rate_interval])",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "Proposals pending",
      "description": "Raft proposals waiting to be committed. This is the backlog. Sustained non-zero means the leader can't commit fast enough (because fsync is slow). During incidents this spikes as writes queue up waiting for disk. Drops back to zero once the fsync pressure passes and the leader catches up.",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 15 },
      "id": 6,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "axisBorderShow": false,
            "axisSoftMax": 50,
            "thresholdsStyle": { "mode": "area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 5 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "etcd_server_proposals_pending{job=\"kube-etcd\"}",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "Peer round-trip p99",
      "description": "Network latency between etcd members. This panel rules out the network hypothesis. If this is low (<5ms) while WAL fsync is high (>10ms), the bottleneck is definitively disk, not network. Your peer RTT is consistently <2ms, confirming the problem is local disk I/O, not inter-node communication.",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 15 },
      "id": 7,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "axisBorderShow": false,
            "axisSoftMax": 0.01,
            "thresholdsStyle": { "mode": "area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 0.005 },
              { "color": "red", "value": 0.01 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, rate(etcd_network_peer_round_trip_time_seconds_bucket{job=\"kube-etcd\"}[$__rate_interval]))",
          "legendFormat": "{{pod}} -> {{To}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102,
      "title": "Cluster Impact (The Blast Radius)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "apiserver latency p99",
      "description": "99th percentile latency for non-streaming API requests. This is the downstream effect of slow etcd. Every API write (pod creation, lease renewal, configmap update) must wait for etcd to fsync before the apiserver can respond. When fsync takes 15ms+ baseline with 50ms+ spikes, apiserver latency follows. During severe incidents this reaches 5-25 seconds, which is why leader-elected controllers lose their leases (hardcoded 5-second timeout).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 23 },
      "id": 8,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": false,
            "axisBorderShow": false,
            "axisSoftMax": 1,
            "thresholdsStyle": { "mode": "area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum by (le, instance) (rate(apiserver_request_duration_seconds_bucket{verb!~\"WATCH|CONNECT\", job=\"apiserver\"}[$__rate_interval])))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "Ceph mon quorum",
      "description": "Number of Ceph monitors in quorum. Healthy = 3. Drops correlate with the same host-level disturbance that causes etcd slowness: when a control plane node's SATA disk stalls, both etcd and the co-located Ceph mon on that node suffer simultaneously. The mon can't respond to Paxos heartbeats in time and gets voted out of quorum. This is a symptom of the same root cause, not an independent problem.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 23 },
      "id": 9,
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 3,
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "green" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 30,
            "spanNulls": false,
            "axisBorderShow": false,
            "thresholdsStyle": { "mode": "area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "#EAB839", "value": 2 },
              { "color": "green", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "count(ceph_mon_quorum_status == 1)",
          "legendFormat": "mons in quorum",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "Container restarts",
      "description": "Cluster-wide container restarts from all causes. This is the user-visible symptom. During etcd slowness, leader-elected controllers can't renew their leases within the 5-second timeout and get restarted. The pattern is distinctive: many unrelated controllers restart at the same time, which is the signal that the problem is infrastructure (etcd/disk), not any individual app.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 23 },
      "id": 10,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 80,
            "stacking": { "mode": "normal" },
            "axisBorderShow": false,
            "axisSoftMax": 5
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "label_replace(label_replace(sum by (namespace, pod) (increase(kube_pod_container_status_restarts_total[$__rate_interval])) > 0, \"workload\", \"$1\", \"pod\", \"(.*)\"), \"workload\", \"$1\", \"pod\", \"(.+)-[a-f0-9]{7,10}-[a-z0-9]{5}$\")",
          "legendFormat": "{{namespace}} / {{workload}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["incident", "etcd", "ceph"],
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(node_uname_info, nodename)",
        "includeAll": true,
        "label": "Node",
        "multi": true,
        "name": "node",
        "query": { "qryType": 1, "query": "label_values(node_uname_info, nodename)" },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d"]
  },
  "timezone": "browser",
  "title": "Ceph / etcd Incident Overview",
  "uid": "ceph-etcd-incident",
  "version": 1
}
