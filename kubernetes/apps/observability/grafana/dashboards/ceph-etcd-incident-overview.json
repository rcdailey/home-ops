{
  "annotations": {
    "list": []
  },
  "description": "Correlated view of etcd, Ceph mon, apiserver, and node health for incident investigation",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 2,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Cluster Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "etcd WAL fsync p99",
      "description": "99th percentile WAL fsync latency per etcd member. Spikes correlate with disk pressure or I/O contention.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "spanNulls": false,
            "axisBorderShow": false,
            "axisSoftMax": 0.05,
            "thresholdsStyle": { "mode": "dashed" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, rate(etcd_disk_wal_fsync_duration_seconds_bucket{job=\"kube-etcd\"}[$__rate_interval]))",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "apiserver latency p99",
      "description": "99th percentile latency for non-streaming API requests (excludes WATCH/CONNECT). Broken down by API server instance to identify which member is affected.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "spanNulls": false,
            "axisBorderShow": false,
            "axisSoftMax": 1,
            "thresholdsStyle": { "mode": "dashed" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum by (le, instance) (rate(apiserver_request_duration_seconds_bucket{verb!~\"WATCH|CONNECT\", job=\"apiserver\"}[$__rate_interval])))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "Ceph mon quorum",
      "description": "Number of mons in quorum. Healthy = 3. Drop to 2 means one mon lost; drop to 1 means quorum lost and Ceph stalls writes.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 3,
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "green" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 30,
            "spanNulls": false,
            "axisBorderShow": false,
            "thresholdsStyle": { "mode": "dashed" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "green", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "count(ceph_mon_quorum_status == 1)",
          "legendFormat": "mons in quorum",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "etcd Internals",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "etcd leader changes",
      "description": "Count of leader elections per interval. Each bar = one election event. Frequent changes indicate network partitions or resource starvation.",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 10 },
      "id": 4,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "decimals": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50,
            "axisBorderShow": false,
            "axisSoftMax": 3
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(etcd_server_leader_changes_seen_total{job=\"kube-etcd\"}[$__rate_interval])",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "etcd slow applies",
      "description": "Count of raft proposals that took longer than 100ms to apply. High values indicate the etcd leader is under I/O or CPU pressure. Key diagnostic for apiserver latency spikes.",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 10 },
      "id": 15,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "decimals": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50,
            "axisBorderShow": false,
            "axisSoftMax": 10,
            "thresholdsStyle": { "mode": "dashed" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(etcd_server_slow_apply_total{job=\"kube-etcd\"}[$__rate_interval])",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "etcd proposals pending",
      "description": "Raft proposals waiting to be committed. Sustained non-zero indicates leader cannot commit (quorum loss or slow followers).",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 10 },
      "id": 5,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "axisBorderShow": false,
            "axisSoftMax": 50
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "etcd_server_proposals_pending{job=\"kube-etcd\"}",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "etcd peer round-trip p99",
      "description": "99th percentile network latency between etcd peers. High values indicate network issues between control plane nodes.",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 10 },
      "id": 6,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "axisBorderShow": false,
            "axisSoftMax": 0.1,
            "thresholdsStyle": { "mode": "dashed" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, rate(etcd_network_peer_round_trip_time_seconds_bucket{job=\"kube-etcd\"}[$__rate_interval]))",
          "legendFormat": "{{pod}} -> {{To}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 102,
      "title": "Resource Pressure (PSI)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "CPU pressure (some)",
      "description": "Percentage of time at least one task is waiting for CPU. High values indicate CPU saturation.",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 18 },
      "id": 7,
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "axisBorderShow": false,
            "axisSoftMax": 50
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(node_pressure_cpu_waiting_seconds_total[$__rate_interval]) * 100 * on (instance) group_left (nodename) node_uname_info{nodename=~\"$node\"}",
          "legendFormat": "{{nodename}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "Memory pressure (some)",
      "description": "Percentage of time at least one task is waiting for memory. More sensitive than 'full stall'; catches partial pressure before total system stall.",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 18 },
      "id": 8,
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "axisBorderShow": false,
            "axisSoftMax": 5
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(node_pressure_memory_waiting_seconds_total[$__rate_interval]) * 100 * on (instance) group_left (nodename) node_uname_info{nodename=~\"$node\"}",
          "legendFormat": "{{nodename}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "I/O pressure (some)",
      "description": "Percentage of time at least one task is waiting for I/O. Correlates with disk saturation affecting etcd and Ceph. More sensitive than 'full stall'; a 4-5% spike here can trigger etcd slow applies.",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 18 },
      "id": 9,
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "axisBorderShow": false,
            "axisSoftMax": 10
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(node_pressure_io_waiting_seconds_total[$__rate_interval]) * 100 * on (instance) group_left (nodename) node_uname_info{nodename=~\"$node\"}",
          "legendFormat": "{{nodename}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 106,
      "title": "Disk I/O (CP Nodes)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "Disk device utilization",
      "description": "Fraction of time each physical disk is busy (0-1). Shows per-device I/O contention on CP nodes. sda is the Talos system disk (etcd, kubelet, containerd); nvme is the Ceph OSD. A spike on sda concurrent with etcd slow applies confirms direct I/O contention on etcd's own device.",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 26 },
      "id": 16,
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "axisBorderShow": false,
            "axisSoftMax": 0.5
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(node_disk_io_time_seconds_total{device=~\"sd.*|nvme.*\"}[$__rate_interval]) * on (instance) group_left (nodename) node_uname_info{nodename=~\"$node\"}",
          "legendFormat": "{{nodename}} / {{device}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 104,
      "title": "Workload Impact (CP Nodes)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "Top disk writers (CP nodes)",
      "description": "Top 5 workloads by disk write rate on control plane nodes. Identifies workloads competing with etcd and Ceph mons for I/O.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 34 },
      "id": 12,
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 20,
            "stacking": { "mode": "none" },
            "axisBorderShow": false
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "topk_avg(10, sum by (workload, container) (label_replace(label_replace(sum by (pod, container) (rate(container_fs_writes_bytes_total{node=~\"$node\", namespace!=\"rook-ceph\", container!=\"\", container!=\"POD\"}[$__rate_interval])), \"workload\", \"$1\", \"pod\", \"(.*)\"), \"workload\", \"$1\", \"pod\", \"(.+)-[a-f0-9]{7,10}-[a-z0-9]{5}$\")))",
          "legendFormat": "{{workload}} / {{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "Top CPU consumers (CP nodes)",
      "description": "Top 5 workloads by CPU usage on control plane nodes. Identifies workloads competing with etcd and Ceph mons for CPU.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 34 },
      "id": 13,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 20,
            "stacking": { "mode": "none" },
            "axisBorderShow": false
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "topk_avg(10, sum by (workload, container) (label_replace(label_replace(sum by (pod, container) (rate(container_cpu_usage_seconds_total{node=~\"$node\", container!=\"\", container!=\"POD\"}[$__rate_interval])), \"workload\", \"$1\", \"pod\", \"(.*)\"), \"workload\", \"$1\", \"pod\", \"(.+)-[a-f0-9]{7,10}-[a-z0-9]{5}$\")))",
          "legendFormat": "{{workload}} / {{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 },
      "id": 103,
      "title": "Logs",
      "type": "row"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "title": "etcd logs",
      "description": "etcd service logs from Talos. Shows 'apply request took too long' warnings during slow applies and leader election messages.",
      "type": "logs",
      "gridPos": { "h": 10, "w": 8, "x": 0, "y": 43 },
      "id": 10,
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "editorMode": "code",
          "expr": "{app=\"etcd\"} AND (level:warning OR level:warn OR _msg:\"elected leader\" OR _msg:\"lost leader\")",
          "queryType": "instant",
          "maxLines": 500,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "title": "Ceph logs",
      "description": "Ceph mon/OSD/MDS logs from rook-ceph namespace. All levels shown for context during incidents.",
      "type": "logs",
      "gridPos": { "h": 10, "w": 8, "x": 8, "y": 43 },
      "id": 17,
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "editorMode": "code",
          "expr": "{namespace=\"rook-ceph\"}",
          "queryType": "instant",
          "maxLines": 500,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "title": "Kernel messages",
      "description": "Kernel ring buffer (dmesg) from all nodes via Talos KmsgLogConfig.",
      "type": "logs",
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 43 },
      "id": 11,
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "editorMode": "code",
          "expr": "{app=\"kernel\"}",
          "queryType": "instant",
          "maxLines": 500,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 53 },
      "id": 105,
      "title": "Pod Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "title": "Container restarts",
      "description": "Cluster-wide container restarts (all causes: OOM, liveness probe failure, crash, SIGKILL). Empty when healthy. Spikes correlate with infrastructure stress in rows above.",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 54 },
      "id": 14,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 80,
            "stacking": { "mode": "normal" },
            "axisBorderShow": false,
            "axisSoftMax": 5
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
