{
  "$schema": "https://opencode.ai/config.json",
  "formatter": {
    "yamlfmt": {
      "command": ["yamlfmt", "$FILE"],
      "extensions": [".yaml", ".yml"]
    },
    "shfmt": {
      "disabled": true
    }
  },
  "permission": {
    "bash": {
      // kubectl: catch-all ask, deny GitOps-breaking mutations
      "kubectl *": "ask",
      "kubectl apply*": "deny",
      "kubectl apply -f /tmp/*": "ask",
      "kubectl create*": "deny",
      "kubectl create job*--from=cronjob*": "allow",
      "kubectl edit*": "deny",
      "kubectl replace*": "deny",
      "kubectl label*": "deny",
      "kubectl taint*": "deny",
      "kubectl cordon*": "deny",
      "kubectl uncordon*": "deny",
      "kubectl port-forward*": "deny",

      // talosctl: catch-all ask, deny infrastructure mutations
      "talosctl *": "ask",
      "talosctl apply-config*": "deny",
      "talosctl upgrade*": "deny",
      "talosctl reset*": "deny",
      "talosctl reboot*": "deny",
      "talosctl shutdown*": "deny",
      "talosctl patch*": "deny",
      "talosctl edit*": "deny",
      "talosctl bootstrap*": "deny",
      "talosctl kubeconfig*": "deny",

      // flux: catch-all ask, deny infrastructure mutations
      "flux *": "ask",
      "flux install*": "deny",
      "flux uninstall*": "deny",
      "flux bootstrap*": "deny",
      "flux delete*": "deny",
      "flux reconcile*": "deny",

      // helm: catch-all ask, deny GitOps-bypassing mutations
      "helm *": "ask",
      "helm install*": "deny",
      "helm upgrade*": "deny",
      "helm uninstall*": "deny",
      "helm rollback*": "deny",

      // others: complete deny
      "just *": "deny"
    }
  }
}
