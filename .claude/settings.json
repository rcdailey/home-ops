{
  "permissions": {
    "allow": [
      "Bash(black:*)",
      "Bash(flux build:*)",
      "Bash(flux diff:*)",
      "Bash(helm:*)",
      "Bash(kubeconform:*)",
      "Bash(kubectl exec:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl logs:*)",
      "Bash(kustomize build:*)",
      "Bash(mise env:*)",
      "Bash(mise ls:*)",
      "Bash(scripts/app-scout.sh:*)",
      "Bash(sops:*)",
      "Bash(talosctl:*)",
      "Bash(task:*)",
      "mcp__github__get_*",
      "mcp__github__search_*",
      "mcp__k8s__exec_in_pod",
      "mcp__k8s__kubectl_*"
    ],
    "deny": [
      "mcp__k8s__kubectl_delete"
    ]
  },
  "enabledMcpjsonServers": ["k8s"]
}
